@using EcoMeal.Site.Components.OrderCard

@if (Orders is null)
{
    <p>Loading...</p>
}
else
{
    @if (!string.IsNullOrEmpty(AppService.Message))
    {
        <div class="alert alert-dismissible fade show text-dark fw-semibold"
             style="background: linear-gradient(135deg, #B2DFDB, #80CBC4); border: none;">
            <i class="bi bi-check-circle-fill me-2"></i>
            @AppService.Message
        </div>
    }

    <div class="row mb-4 g-3">

        <div class="col-12 col-md-4">
            <label class="form-label fw-bold mb-1">
                Restaurant
            </label>

            <InputSelect class="form-select"
                         @bind-Value="SelectedBusiness"
                         @bind-Value:after="FilterOrders">

                <option value="0">
                    Toate restaurantele
                </option>

                @foreach (var business in Businesses)
                {
                    <option value="@business.Id">
                        @business.Name
                    </option>
                }

            </InputSelect>
        </div>

        <div class="col-12 col-md-4">
            <label class="form-label fw-bold mb-1">
                Status comandă
            </label>

            <InputSelect class="form-select"
                         @bind-Value="SelectedStatus"
                         @bind-Value:after="FilterOrders">

                <option value="">
                    Toate comenzile
                </option>

                <option value="Aprobata">
                    Aprobate
                </option>

                <option value="Plasata">
                    Plasate
                </option>

            </InputSelect>
        </div>

    </div>

    <div class="row g-3">

        @if (!OrdersFiltered.Any())
        {
            <p>Nu există comenzi.</p>
        }
        else
        {
            @foreach (var order in OrdersFiltered)
            {
                <OrderCard order="@order"
                           IsAdmin="@IsAdmin"
                           OnApprove="@OnApprove"
                           OnCancel="@OnCancel" />
            }
        }

    </div>
}