@namespace EcoMeal.Site.Components.PackageCard
@using Microsoft.AspNetCore.Components.Authorization
<div class="card w-100" style="max-width:350px">
    <div class="card-body rounded-2 shadow border border-1 border-dark card-hover">
        <p class="card-title text-black fs-4 fw-bold text-center">@Package.Name</p>
        <p class="card-text text-primary-emphasis fs-6 fw-bold text-center">@Package.Description</p>
        
        <i class="bi bi-coin me-2"></i>
        <span class="card-text text-dark fw-bold fs-6">@Package.Price lei</span>
        
        <br>

        <i class="bi bi-calendar me-2"></i>
        <span class="card-text text-dark fw-bold fs-6"> @Package.StartPickup</span>

        <br>

        <i class="bi bi-calendar-check me-2"></i>
        <span class="card-text text-dark fw-bold fs-6">@Package.EndPickup</span>

        <div class="d-flex justify-content-between align-items-center">
        <AuthorizeView Roles="Admin">
            <div class="mt-3">
                <button class="btn btn-danger rounded-5 btn-sm" @onclick="Delete" @onclick:stopPropagation="true"> Șterge! </button>
                <button class="btn btn-primary rounded-5 btn-sm" @onclick="Update" @onclick:stopPropagation="true"> Editează! </button>
            </div>
        </AuthorizeView>
        </div>
    </div>
</div>

