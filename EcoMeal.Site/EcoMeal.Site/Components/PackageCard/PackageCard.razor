@namespace EcoMeal.Site.Components.PackageCard
@using Microsoft.AspNetCore.Components.Authorization

<div class="card card-hover w-100 h-100 shadow-sm border border-1 border-dark rounded-3 overflow-hidden"
     style="max-width: 320px;">

    <img src="@Package.Image"
         class="card-img-top"
         alt="@Package.Name"
         style="height: 200px; object-fit: cover;" />


    <div class="card-body d-flex flex-column">

        <h5 class="card-title text-dark fw-bold mb-3">
            @Package.Name
        </h5>


        <p class="card-text text-primary-emphasis fw-bold">
            @Package.Description
        </p>


        <div class="mb-2">

            <i class="bi bi-coin me-2"></i>

            <span class="text-dark fw-bold">
                Preț: @Package.Price lei
            </span>

        </div>


        <div class="mb-2">

            <i class="bi bi-calendar me-2"></i>

            <span class="text-dark fw-bold">
                De la: @Package.StartPickup
            </span>

        </div>


        <div class="mb-3">

            <i class="bi bi-calendar-check me-2"></i>

            <span class="text-dark fw-bold">
                Până la: @Package.EndPickup
            </span>

        </div>


        <div class="mt-auto">

            <AuthorizeView>

                <div class="w-100 mb-2">

                    <button class="btn btn-success rounded-5 w-100"
                            @onclick="Reserve"
                            @onclick:stopPropagation="true">

                        Rezervă!

                    </button>

                </div>

            </AuthorizeView>


            <AuthorizeView Roles="Admin">

                <div class="d-flex gap-2">

                    <button class="btn btn-danger rounded-5 btn-sm"
                            @onclick="Delete"
                            @onclick:stopPropagation="true">

                        Șterge!

                    </button>


                    <button class="btn btn-primary rounded-5 btn-sm"
                            @onclick="Update"
                            @onclick:stopPropagation="true">

                        Editează!

                    </button>

                </div>

            </AuthorizeView>

        </div>

    </div>

</div>