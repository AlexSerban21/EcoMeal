@namespace EcoMeal.Site.Components.BusinessCard
@using Microsoft.AspNetCore.Components.Authorization
<div class="card w-100" style="max-width:320px" @onclick="NavigateToDetails">
    <div class="card-body rounded-2 shadow border border-1 border-dark card-hover">
        <p class="card-title text-black fs-4 fw-bold text-center">@Business.Name</p>
        <p class="card-text text-primary-emphasis fs-6 fw-bold text-center">@Business.Description</p>
        
        <i class="bi bi-geo-alt-fill me-2"></i>
        <span class="card-text text-dark fw-bold fs-6">@Business.Adress</span>

        <br>

        <i class="bi bi-envelope me-2"></i>
        <span class="card-text text-dark fs-6 fw-bold">@Business.Contact</span>

        <div class="d-flex justify-content-between align-items-center">
        <AuthorizeView Roles="Admin"> 
            <div class="mt-3">
                <button class="btn btn-danger rounded-5 btn-sm" @onclick="Delete" @onclick:stopPropagation="true"> Șterge! </button>
                <button class="btn btn-primary rounded-5 btn-sm" @onclick="Update" @onclick:stopPropagation="true"> Editează! </button>
            </div>
        </AuthorizeView>
        </div>
    </div>
</div>