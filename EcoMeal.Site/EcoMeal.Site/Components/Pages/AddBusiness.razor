@page "/addBusiness"
@rendermode InteractiveServer

<div class="mx-auto px-3 py-4 card-body rounded-2 border border-1 border-dark " style="max-width: 500px; width: 100%; background:#D8EFD8">
    <p class="text-center fs-2 fw-bold text-dark lh-1">Adaugă restaurant</p>
    <EditForm Model="BusinessAddModel" OnValidSubmit="AddBusinessInService">
        <DataAnnotationsValidator />
        @*@<ValidationSummary />*@

        <label class="form-label fs-6 fw-bold">Nume</label>
        <InputText class="form-control mb-2 rounded-2 shadow border border-1 border-dark"
                   @bind-Value="BusinessAddModel.Name"
                   placeholder="Adauga nume resturant" />

        <ValidationMessage For="@(() => BusinessAddModel.Name)" />

        <label class="form-label fs-6 fw-bold">Adresă</label>
        <InputTextArea @bind-Value="BusinessAddModel.Adress"
                       placeholder="Adresă"
                       rows="4"
                       class="form-control mb-2 rounded-2 shadow border border-1 border-dark" />

        <ValidationMessage For="@(() => BusinessAddModel.Adress)" />
    
        <label class="form-label fs-6 fw-bold">Descriere</label>
        <InputTextArea @bind-Value="BusinessAddModel.Description"
                       placeholder="Descriere"
                       rows="4"
                       class="form-control mb-2 rounded-2 shadow border border-1 border-dark" />

        <ValidationMessage For="@(() => BusinessAddModel.Description)" />
    
        <label class="form-label fs-6 fw-bold">Contact</label>
        <InputTextArea @bind-Value="BusinessAddModel.Contact"
                       placeholder="Contact"
                       rows="4"
                       class="form-control mb-2 rounded-2 shadow border border-1 border-dark" />

        <ValidationMessage For="@(() => BusinessAddModel.Contact)" />

        <label class="form-label fs-6 fw-bold">Tip restaurant</label>
        <InputSelect @bind-Value="BusinessAddModel.BusinessTypeId"
                     class="form-control mb-2 rounded-2 shadow border border-1 border-dark">
            <option value="0"
                    disabled>Alege tipul...</option>
            @if (BusinessTypes is not null)
            {
                foreach (var packageType in BusinessTypes)
                {
                    <option value="@packageType.Id">@packageType.Name</option>
                }
            }
        </InputSelect>

        <ValidationMessage For="@(() => BusinessAddModel.BusinessTypeId)" />

        <button type="submit" class="btn btn-success rounded-5">Adaugă Restaurant</button>

    </EditForm>
</div>
