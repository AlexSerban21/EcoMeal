@page "/"
@using EcoMeal.Site.Components.BusinessList
@using Microsoft.AspNetCore.Components.Authorization
<PageTitle>Home</PageTitle>
<div class="card border-0 shadow rounded-4 overflow-hidden mb-5"
     style="background: linear-gradient(to right, #1B5E20, #4CAF50);">

    <div class="card-body text-center p-5 fs-1 fw-bold text-white">

        <h1 class="display-4 fw-bold text-white mb-3">
            EcoMeal
        </h1>

        <h2 class="fs-3 fw-bold text-white mb-3">
            Bucură-te de mâncare bună. Salvează bani. Protejează planeta.
        </h2>

        <p class="fs-5 fw-bold text-white mb-0">
            Descoperă restaurante partenere și pachete cu mâncare la prețuri accesibile,
            contribuind în același timp la reducerea risipei alimentare.
        </p>

    </div>
</div>


<div class="mt-5 mb-5">
    <div class="text-center mb-4">
        <h2 class="fw-bold">
            De ce EcoMeal? 🌱
        </h2>
        <p class="fw-bold">
            Împreună putem face o diferență pentru oameni și pentru planetă.
        </p>
    </div>
    <div class="row g-4">

        <div class="col-12 col-sm-6 col-lg-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 text-center"
                 style="background: linear-gradient(135deg, #F9A825, #FFD54F);">

                <div class="card-body p-4">

                    <div class="fs-1 mb-3">
                        💰
                    </div>

                    <h4 class="fw-bold" style="color: #1F2937;">
                        Economisești bani
                    </h4>

                    <p class="fw-bold" style="color: #374151;">
                        Bucură-te de mâncare delicioasă la prețuri mai mici.
                    </p>

                </div>
            </div>
        </div>


        <div class="col-12 col-sm-6 col-lg-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 text-center"
                 style="background: linear-gradient(135deg, #1976D2, #64B5F6);">

                <div class="card-body p-4">

                    <div class="fs-1 mb-3">
                        🌍
                    </div>

                    <h4 class="fw-bold" style="color: #FFFFFF;">
                        Protejezi planeta
                    </h4>

                    <p class="fw-bold" style="color: #E3F2FD;">
                        Contribui la reducerea risipei alimentare și la protejarea mediului.
                    </p>

                </div>
            </div>
        </div>


        <div class="col-12 col-sm-6 col-lg-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 text-center"
                 style="background: linear-gradient(135deg, #E53935, #EF9A9A);">

                <div class="card-body p-4">

                    <div class="fs-1 mb-3">
                        🤝
                    </div>

                    <h4 class="fw-bold" style="color: #FFFFFF;">
                        Susții restaurantele locale
                    </h4>

                    <p class="fw-bold" style="color: #FFF3F3;">
                        Sprijini restaurantele locale și ajuți la reducerea risipei alimentare.
                    </p>

                </div>
            </div>
        </div>

    </div>
</div>

<div class="mt-5 mb-4">

    <div class="mb-4">

        <h2 class="fw-bold text-dark mb-2 text-center">
            Restaurante partenere
        </h2>

        <p class="fw-bold text-dark mb-0 text-center">
            Descoperă restaurantele disponibile și filtrează rezultatele.
        </p>

    </div>

</div>
<BusinessList Businesses="@Businesses" ShowAddBusinessButton="true" />
