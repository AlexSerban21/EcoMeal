@inherits LayoutComponentBase

<div class="page" style="background-color: #F1F8E9;">
    <main>
        <div style="background-color: #4CAF50;" class="top-row justify-content-start">
            <a href="." class="text-white fs-5 fw-bold" style="margin-left:5px;font-family: 'Trebuchet MS'">EcoMeal</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
